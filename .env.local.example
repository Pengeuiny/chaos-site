# Copy this file to `.env.local` and fill in values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API).
#
# .env.local is gitignored and will NOT be committed.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser (protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SECRET. Server-side only, bypasses RLS.
# Required for the /admin page to create shows and calendar events.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin page (/admin) ---
# Password to access the admin dashboard.
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie. Use a long random string.
# If left blank, ADMIN_PASSWORD is used as the signing key.
ADMIN_SESSION_SECRET=

# --- Social publishing (/admin/social) ---
# Long-lived Facebook Page Access Token (not a short-lived user token —
# see the setup instructions on /admin/social for how to generate one).
META_PAGE_ACCESS_TOKEN=
# The CHS CHAOS Facebook Page ID.
META_PAGE_ID=
# The Instagram Business Account ID linked to that Page.
META_IG_USER_ID=
