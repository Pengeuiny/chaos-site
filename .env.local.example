# Copy this file to `.env.local` and fill in values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API).
#
# .env.local is gitignored and will NOT be committed.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser (protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SECRET. Server-side only, bypasses RLS.
# Leave blank unless you need privileged server actions.
SUPABASE_SERVICE_ROLE_KEY=
